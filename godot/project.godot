; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Rift"
config/description="Co-op roguelike — trinity combat, movement removed. See ../PORT-PLAN.md"
run/main_scene="res://game/world_shell.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0.027451, 0.027451, 0.0470588, 1)
boot_splash/show_image=false

[autoload]

UiTheme="*res://game/ui/ui_theme.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.027451, 0.027451, 0.0470588, 1)
